    "outDir": "dist/server",
    "rootDir": "server",
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": ["server/**/*.ts"],
  "exclude": [
    "server/worker.ts",
    "server/db/d1-adapter.ts",
    "server/types/bindings.ts",
    "**/*.test.ts"
